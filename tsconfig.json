{
  "compilerOptions": {
    "target": "ES2023",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "src/**/*.js",
    "test/**/*.js",
    "e2e/**/*.js",
    "eslint.config.js",
    "vitest.config.js",
    "e2e/playwright.config.js"
  ],
  "exclude": ["node_modules", "public", "data"]
}
