{
  "name": "whats-for-dinner",
  "version": "1.0.0",
  "private": true,
  "description": "Docker-friendly meal planning and dinner selection app built with Node, Express, and SQLite.",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "migrate": "node src/db/migrate.js",
    "seed": "node src/db/seed.js",
    "db:init": "npm run migrate && npm run seed",
    "lint": "eslint .",
    "format": "prettier --check .",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.1",
    "@types/node": "^22.14.1",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "supertest": "^7.1.0",
    "typescript": "^5.8.3",
    "vitest": "^3.0.9"
  }
}
